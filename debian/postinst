#!/bin/sh
set -e
export UV_PYTHON_INSTALL_DIR=/opt/forge/python
uv venv --clear --python 3.14.0 /opt/forge/venv
WHL=$(find /opt/forge -maxdepth 1 -name '*.whl' -print -quit)
if [ -z "$WHL" ]; then
    echo "Error: no .whl file found in /opt/forge/" >&2
    exit 1
fi
uv pip install --python /opt/forge/venv/bin/python --extra-index-url https://__FORGEJO_HOST__/api/packages/__PACKAGE_OWNER__/pypi/simple/ --force-reinstall "$WHL"
find /opt/forge/python /opt/forge/venv -type d -exec chmod 755 {} +
find /opt/forge/python /opt/forge/venv -type f -exec chmod a+r {} +
