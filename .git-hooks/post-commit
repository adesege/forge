#!/usr/bin/env bash
# Post-commit hook: create an annotated tag if a version bump was requested
# during the pre-commit phase.
set -euo pipefail

GIT_DIR="$(git rev-parse --git-dir)"
BUMP_FILE="${GIT_DIR}/BUMP_VERSION"

if [ -f "$BUMP_FILE" ]; then
    VERSION=$(cat "$BUMP_FILE")
    git tag -a "v${VERSION}" -m "Release v${VERSION}"
    rm -f "$BUMP_FILE"
    echo "==> Tagged: v${VERSION}"
fi
