#!/usr/bin/env bash
# Conventional commit format check (advisory, non-blocking).
# AI tools like git-good generate free-form messages — that's fine.
set -euo pipefail

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(head -1 "$COMMIT_MSG_FILE")

PATTERN="^(feat|fix|docs|style|refactor|test|chore|ci|perf|build|release)(\(.+\))?: .{1,72}$"

if ! echo "$COMMIT_MSG" | grep -qE "$PATTERN"; then
    echo "Hint: commit message is not in Conventional Commits format."
    echo "  Expected: <type>(<scope>): <description>"
    echo "  Types: feat, fix, docs, style, refactor, test, chore, ci, perf, build"
    echo ""
    echo "  This is advisory only — AI-generated messages (git-good) are accepted as-is."
fi
